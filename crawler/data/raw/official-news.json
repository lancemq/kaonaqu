    "content": "无障碍 首页 > 政务公开 > 重点工作 > 入学报考与招生 > 普通高校招考与加分 上海市教育委员会关于印发《2026年上海市部分普通高校专科层次实行依法自主招生改革试点方案》的通知 索取号：AA4307003-2026-001 发布日期：2026-01-16字体 [ 大 中 小 ] 内容概述 沪教委学〔2026〕4号 各区教育局、后方基地教育处，各有关高等学校： 为进一步深化我市普通高等学校招生考试制度改革，做好普通高校招生改革试点工作，市教委制定了《2026年上海市部分普通高校专科层次实行依法自主招生改革试点方案》（见附件），现印发给你们，请认真按照执行。 附件：2026年上海市部分普通高校专科层次实行依法自主招生改革试点方案 上 海 市 教 育 委 员 会 2026年1月12日 查阅全文 1、上海市教育委员会关于印发《2026年上海市部分普通高校专科层次实行依法自主招生改革试点方案》的通知（沪教委学〔2026〕4号）.doc [返回上一页] [ 打印本页 ] 繁体版 不能读取Jquery文件 不能读取Jquery文件 if (isMobile.any()) { document.write('<scri' + 'pt src=\"//edu.sh.gov.cn/edu-assets-20200601/js/2016/mobile.js\\\"></s' + 'cript><noscript>不能加载移动端JS文件</noscript>'); } else { document.write('<scri' + 'pt src=\"//edu.sh.gov.cn/edu-assets-20200601/js/2016/desktop.js\\\"></s' + 'cript><noscript>不能加载PC端JS文件</noscript>'); } function stringToDate(str) { var dateStrs = str.split('-'); var year = parseInt(dateStrs[0], 10); var month = parseInt(dateStrs[1], 10) - 1; var day = parseInt(dateStrs[2], 10); var date = new Date(year, month, day); return date; } let isContent = document.getElementById('ivs_content'); let contentDate1 = \"2026-01-16\"; let contentDate2 = \"2023-12-13\"; var time1 = stringToDate(contentDate1); var time2 = stringToDate(contentDate2); if(time1 >= time2){ isContent.style.textIndent = \"0\"; } const token = UUID().replace(/-/g, \"\"); const url = \"https://hd.sh.gov.cn/front\"; const contentId = \"87407f6b470d49428acf8281b3a4e61f\"; const site_id = \"0015\"; function UUID() { return \"xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx\".replace(/[xy]/g, function(c) { var r = (Math.random() * 16) | 0, v = c == \"x\" ? r : (r & 0x3) | 0x8; return v.toString(16); }); } jQuery(document).ready(function() { const time = setInterval(() => { if ($) { clearInterval(time); $.ajax({ type: \"POST\", url: url + \"/comment/comment/page\", data: { contentId, pageNo: 1, pageSize: 5, }, success: (res) => { let result = \"\"; console.log(res, \"item\"); if ( !res.data.records || (res.data.records && !res.data.