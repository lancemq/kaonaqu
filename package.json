    "crawl:social": "node crawler/src/crawlers/social-platforms.js",
    "data:process": "node crawler/src/process-data.js",
    "data:policies:markdown": "node scripts/build-policy-markdown.mjs",
    "data:schools:markdown": "node scripts/sync-detail-markdown.mjs",
    "data:schools:enrich": "node scripts/enrich-school-markdown-unified.mjs",
    "data:schools:enrich:dry": "node scripts/enrich-school-markdown-unified.mjs --dry-run --limit 20",
    "data:schools:polish:top50": "node scripts/polish-top50-runner.mjs --all",
