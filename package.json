    "seo:build": "node scripts/generate-seo.js",
    "crawl:policies": "node crawler/src/crawlers/policies-official.js",
    "crawl:news": "node crawler/src/crawlers/news-official.js",
    "crawl:schools": "node crawler/src/crawlers/schools-official.js",
