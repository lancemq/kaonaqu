    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.7",
    "next": "^16.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "nodemon": "^3.0.1"
  }
