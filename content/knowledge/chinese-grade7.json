                      "type": "text",
                      "text": "关键点"
                    }
                  ]
                },
                {
                  "type": "element",
                  "tag": "p",
                  "children": [
                    {
                      "type": "text",
                      "text": "古诗文第一步是读懂，不是直接背赏析。"
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "tag": "div",
              "className": "concept-card",
              "children": [
                {
                  "type": "element",
                  "tag": "h4",
                  "children": [
                    {
                      "type": "text",
                      "text": "常考点"
                    }
                  ]
                },
                {
                  "type": "element",
                  "tag": "p",
                  "children": [
                    {
                      "type": "text",
                      "text": "词义解释、句子翻译、内容概括、人物品质和诗歌情感。"
                    }
                  ]
                }
              ]
            },
            {
              "type": "element",
              "tag": "div",
              "className": "concept-card",
              "children": [
                {
                  "type": "element",
                  "tag": "h4",
                  "children": [
                    {
                      "type": "text",
                      "text": "易错内容"
                    }
                  ]
                },
                {
                  "type": "element",
                  "tag": "p",
                  "children": [
                    {
                      "type": "text",
                      "text": "把现代汉语意思直接套进文言句子，或翻译时漏掉省略成分。"
                    }
                  ]
                }
              ]
            }
          ]
        },
