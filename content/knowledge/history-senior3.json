          ]
        },
        {
          "type": "element",
          "tag": "h4",
          "className": "exam-title",
          "children": [
            {
              "type": "text",
              "text": "以“中国近代经济结构的变动”为题写小论文。"
            }
          ]
        },
        {
          "type": "element",
          "tag": "p",
          "className": "exam-q",
