              "children": [
                {
                  "type": "text",
                  "text": "2023 上海等级考·论述"
                }
              ]
            },
            {
              "type": "element",
              "tag": "span",
              "className": "exam-tag points",
              "children": [
                {
                  "type": "text",
                  "text": "12分"
                }
