          ]
        },
        {
          "type": "element",
          "tag": "li",
          "children": [
            {
              "type": "text",
              "text": "语言赏析：从用词、句式、修辞三个角度品味语言"
            }
          ]
        }
      ]
    },
    {
      "type": "element",
      "tag": "div",
      "children": [
        {
          "type": "element",
          "tag": "p",
          "children": [
            {
              "type": "element",
