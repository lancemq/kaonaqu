            {
              "type": "element",
              "tag": "li",
              "children": [
                {
                  "type": "text",
                  "text": "所有理科都要按“概念 - 条件 - 公式/过程 - 应用题型”建立统一笔记方式。"
                }
              ]
            }
          ]
