PORT=8080
HOST=127.0.0.1

# Supabase server-side config
KNQ_SUPABASE_URL=https://your-project-ref.supabase.co
KNQ_SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# API 写操作鉴权（POST/PUT/DELETE 必须带 Authorization: Bearer <token>）
# 生成：openssl rand -hex 32  未配置时所有写操作一律 403（fail-closed）
KNQ_ADMIN_TOKEN=replace-with-a-long-random-string

# CORS 白名单（逗号分隔，与请求 Origin 精确匹配；不可用 *）
KNQ_API_ALLOW_ORIGINS=http://localhost:3000,https://kaonaqu.xyz

# Optional custom table names
# SUPABASE_SCHOOLS_TABLE=content_schools
# SUPABASE_POLICIES_TABLE=content_policies
# SUPABASE_NEWS_TABLE=content_news

# Optional Blob fallback
# BLOB_READ_WRITE_TOKEN=
# BLOB_DATA_PREFIX=runtime-data
