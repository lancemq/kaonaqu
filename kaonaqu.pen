                      "name": "faqQ3",
                      "fill": "$--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Q3. 看校时重点看什么？",
                      "lineHeight": 1.6,
                      "fontFamily": "Geist",
                      "fontSize": 16,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
