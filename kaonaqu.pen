                      "fontSize": 12,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "W64Ot",
                      "name": "fit1",
                      "fill": "$--foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "适合：自驱力强、学术兴趣稳定、能适应高标准同伴环境的学生。",
                      "lineHeight": 1.7,
                      "fontFamily": "Geist",
                      "fontSize": 15,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "tLzzM",
