                      "fill": "$--muted-foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "除了硬件与成绩，更应观察课程展示、学生表达状态、老师交流风格和校园日常秩序感。",
                      "lineHeight": 1.65,
                      "fontFamily": "Geist",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                }
